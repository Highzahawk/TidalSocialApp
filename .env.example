# Postgres + Redis
DATABASE_URL=postgres://user:pass@localhost:5432/tidal_social
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this

# TIDAL OAuth
TIDAL_CLIENT_ID=your_id
TIDAL_CLIENT_SECRET=your_secret
TIDAL_REDIRECT_URI=http://localhost:3000/api/auth/tidal/callback

# Last.fm
LASTFM_API_KEY=your_key
LASTFM_API_SECRET=your_secret
LASTFM_REDIRECT_URI=http://localhost:3000/api/auth/lastfm/callback
