{
  "manifest_version": 3,
  "name": "Tidal Social Overlay",
  "version": "0.1.0",
  "description": "Friends feed + collab controls inside listen.tidal.com",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://tidal.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://tidal.com/*"
      ],
      "css": ["styles.css"],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}