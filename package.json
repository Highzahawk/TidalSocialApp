{
  "name": "tidal-social",
  "private": true,
  "version": "0.1.0",
  "packageManager": "ypnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "extension"
  ],
  "scripts": {
    "postinstall": "npm run prisma:generate",
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/web",
    "worker": "npm run start --workspace=apps/worker",
    "lint": "npm run lint --workspaces",
    "prisma:generate": "cd apps/web && npm run prisma generate"
  }
}